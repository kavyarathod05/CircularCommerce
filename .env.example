# =============================================================================
# SecondLife Commerce — Environment Configuration
# Copy to .env (repo root) and backend/ml-service/.env for local development.
# NEVER commit real secrets.
# =============================================================================

# --- Core API ---
APP_ENV=development
APP_BASE_URL=http://localhost:5173
AWS_REGION=us-east-1

# --- Authentication (REQUIRED in production) ---
JWT_SECRET=change-me-to-a-long-random-string

# --- DynamoDB feature flags ---
USE_DYNAMODB_CATALOG=1
USE_DYNAMODB_VTO=0

# --- AI / ML providers (optional — features degrade gracefully without keys) ---
GEMINI_API_KEY=
HF_API_KEY=
HF_TOKEN=
GS1_API_KEY=

# --- AWS credentials (use IAM roles in production; local dev only) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Caching & messaging ---
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- Blockchain DPP ---
BLOCKCHAIN_MODE=hash-only
INFURA_PROJECT_ID=
DPP_CONTRACT_ADDRESS=

# --- Frontend (apps/commerce-web/.env) ---
VITE_ML_API_URL=http://127.0.0.1:8000
VITE_AWS_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com/Prod
VITE_WS_URL=http://127.0.0.1:8765
